# Copy to `.env.local` (git-ignored) for local overrides.
#
# Base URL of the opentcs-bff service. Leave empty in dev to use Vite's
# `server.proxy` (see vite.config.ts). In production the SPA is served from
# the same origin as the BFF via nginx, so this is also typically empty.
VITE_BFF_BASE_URL=

# X-Api-Access-Key value sent on every BFF request. Empty disables auth (the
# BFF treats `bff.security.accessKey=""` as auth-disabled). Never commit a
# real key — keep production keys in `.env.production.local` only.
VITE_BFF_ACCESS_KEY=
